# ==============================================================================
# .gitignore — dc-muni project (Data Centers and Municipality Finances)
# Forked from claude-code-my-workflow 2026-05-10 and retargeted for empirical paper.
# ==============================================================================

# ---- LaTeX build artifacts -------------------------------------------------
*.aux
*.bbl
*.blg
*.fdb_latexmk
*.fls
*.log
*.nav
*.out
*.snm
*.toc
*.vrb
*.synctex.gz
*.run.xml
*-blx.bib

# Paper compile artifacts
paper/*.aux
paper/*.bbl
paper/*.blg
paper/*.log
paper/*.out
paper/*.synctex.gz
paper/*.toc

# ---- Stata logs & smcl -----------------------------------------------------
*.smcl
scripts/stata/*.log
scripts/stata/*.smcl

# ---- Data --------------------------------------------------------------------
# data/raw is a symlink to /Users/fangyu/claude/datacenter/raw — gitignore it.
# Each collaborator creates their own symlink (see CLAUDE.md).
data/raw
data/datacenter

# Raw vendor data — never commit (multi-GB SDC + MSRB files)
data/sdc_muni/
data/msrb/
*.sas7bdat
*.rar

# Logs directory — script outputs only, not source
logs/

# Intermediate files (regenerated by 01_import.do); never commit.
data/intermediate/*
!data/intermediate/.gitkeep

# Derived files: the .gitkeep ships, individual .dta are project-internal.
# Selectively commit small / load-bearing files; ignore large ones by default.
data/derived/*.dta
# Long-format aggregations (10-200 MB); regenerable from raw + scripts
data/derived/*_long.csv
data/derived/sdc_deal_spread.csv
data/derived/sdc_deal_coupon.csv
data/derived/county_year_panel.csv
data/derived/county_year_panel_v2.csv
data/derived/county_year_panel_v3.csv
data/derived/county_year_panel_v4.csv
data/derived/acfr_county_year_wide.csv
data/derived/acfr_2017_county_wide.csv
data/derived/sdc_issuer_county_full.csv
data/derived/sdc_issuer_county_full_v2.csv
data/derived/sdc_issuer_county_full_v3.csv
!data/derived/.gitkeep

# External data (ACFR, MSRB, NCSL, etc.) — gitignored; collected per-machine.
data/external/*
!data/external/.gitkeep
# Whitelist the hand-curated SDC issuer override table (small, load-bearing, team-maintained).
!data/external/sdc_issuer_overrides.csv

# ---- Output ----------------------------------------------------------------
# Tables (.tex) ARE committed — they're consumed by paper/main.tex via \input{}.
# Figures: PDFs committed (small, deterministic); PNGs ignored (regenerable from PDF).
output/figures/*.png
output/tables/*.aux

# ---- Python ----------------------------------------------------------------
__pycache__/
*.pyc
*.pyo

# ---- R ---------------------------------------------------------------------
.Rproj.user/
.Rhistory
.RData
.Rdata
Rplots.pdf

# R analysis outputs (generated artifacts; keep scripts, ignore outputs)
scripts/R/_outputs/

# ---- Stata orchestrator artifacts at root (when invoked from repo root) -----
# `-e` mode auto-logs to cwd; the `log using` directive in 00_run_all.do also
# writes scripts/stata/00_run_all.log. The repo-root copy is a side effect.
/00_run_all.log

# ---- OS files --------------------------------------------------------------
.DS_Store
Thumbs.db

# ---- Claude Code local files (machine-specific) ----------------------------
.claude/settings.local.json
.claude/state/
CLAUDE.local.md

# ---- IDE -------------------------------------------------------------------
.vscode/*
!.vscode/settings.json
.idea/
*.swp
*.swo
*~

# ---- Quarto ----------------------------------------------------------------
.quarto/

# ---- quality_reports — per-project, not inherited from template ------------
quality_reports/plans/*
quality_reports/specs/*
quality_reports/session_logs/*
quality_reports/merges/*
quality_reports/decisions/*
quality_reports/checkpoints/*
quality_reports/preregistrations/*
!quality_reports/plans/.gitkeep
!quality_reports/specs/.gitkeep
!quality_reports/session_logs/.gitkeep
!quality_reports/merges/.gitkeep
!quality_reports/decisions/.gitkeep
!quality_reports/checkpoints/.gitkeep
!quality_reports/preregistrations/.gitkeep

# Personal memory (machine-specific)
.claude/state/personal-memory.md
